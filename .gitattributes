# Always LF for files that run in Linux containers or CI
*.sh    text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.hcl   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.conf  text eol=lf
*.j2    text eol=lf

# Windows-native files keep CRLF
*.bat   text eol=crlf
*.ps1   text eol=crlf
